{
  "schema_version": "0.1.0",
  "project": "tokamaker-jax",
  "manifest_type": "physics_validation_gates",
  "global_requirements": {
    "no_unimplemented_parity_claims": true,
    "record_fixture_paths": true,
    "record_command": true,
    "record_artifact_paths": true,
    "record_dtype_and_backend": true,
    "record_tolerance": true,
    "record_hardware_for_performance": true
  },
  "gates": [
    {
      "id": "fem-p1-reference-kernels",
      "category": "finite_element",
      "status": "implemented",
      "description": "Validate p=1 reference-triangle nodes, basis functions, gradients, affine maps, degree-2 quadrature, and local mass/stiffness matrices.",
      "command": "python -m pytest tests/test_fem.py",
      "artifact": null,
      "required_checks": [
        "partition_of_unity",
        "kronecker_delta_at_vertices",
        "degree_two_quadrature_exactness",
        "affine_mapping_consistency",
        "physical_gradient_sum_zero",
        "mass_matrix_symmetry",
        "mass_matrix_positive_definite",
        "stiffness_matrix_symmetry",
        "stiffness_constant_nullspace",
        "weighted_mass_constant_scaling",
        "weighted_stiffness_constant_scaling"
      ],
      "pass_rule": {
        "type": "analytic_identity",
        "tolerance_source": "tests/test_fem.py"
      }
    },
    {
      "id": "fem-p1-dense-global-assembly",
      "category": "finite_element",
      "status": "implemented",
      "description": "Validate dense global mass and Laplace stiffness assembly on a two-triangle unit-square mesh.",
      "command": "python -m pytest tests/test_assembly.py",
      "artifact": null,
      "required_checks": [
        "exact_unit_square_mass_matrix",
        "exact_unit_square_stiffness_matrix",
        "sparse_bcoo_matches_dense",
        "matrix_free_apply_matches_dense",
        "weighted_sparse_bcoo_matches_dense",
        "weighted_matrix_free_apply_matches_dense",
        "axisymmetric_inverse_radius_stiffness",
        "grad_shafranov_profile_load_density",
        "symmetry",
        "mass_total",
        "positive_mass_eigenvalues",
        "stiffness_positive_semidefinite",
        "stiffness_row_sum_zero",
        "jit_compatibility",
        "coordinate_gradient_finiteness"
      ],
      "pass_rule": {
        "type": "analytic_identity",
        "tolerance_source": "tests/test_assembly.py"
      }
    },
    {
      "id": "config-toml-validation",
      "category": "configuration",
      "status": "implemented",
      "description": "Validate TOML parsing, region geometry, grid dimensions, solver controls, coil controls, and output paths without solving.",
      "command": "python -m pytest tests/test_cli_validate.py tests/test_config.py",
      "artifact": null,
      "required_checks": [
        "valid_example_config",
        "validate_does_not_solve",
        "invalid_grid_rejected",
        "invalid_region_geometry_rejected",
        "invalid_output_path_rejected"
      ],
      "pass_rule": {
        "type": "schema_and_runtime_validation",
        "tolerance_source": "not_applicable"
      }
    },
    {
      "id": "figure-metadata-and-gui-summaries",
      "category": "plotting_gui",
      "status": "implemented",
      "description": "Validate JSON-ready figure recipes, region table data, and GUI metadata summaries for seed equilibrium and region views.",
      "command": "python -m pytest tests/test_plotting.py tests/test_gui.py",
      "artifact": "docs/_static/region_geometry_seed.png",
      "required_checks": [
        "figure_recipe_json_roundtrip",
        "region_table_json_roundtrip",
        "equilibrium_metadata_summary",
        "plot_metadata_annotation",
        "plotly_region_metadata",
        "gui_table_rows"
      ],
      "pass_rule": {
        "type": "metadata_schema_and_artifact_presence",
        "tolerance_source": "tests/test_plotting.py and tests/test_gui.py"
      }
    },
    {
      "id": "seed-and-local-fem-benchmarks",
      "category": "performance",
      "status": "implemented",
      "description": "Validate executable benchmark helpers and JSON-friendly timing outputs without asserting hardware-independent speed.",
      "command": "python -m pytest tests/test_benchmarks.py",
      "artifact": "docs/_static/benchmark_summary.png",
      "report": "docs/_static/benchmark_report.json",
      "threshold_report": "docs/_static/benchmark_threshold_report.json",
      "thresholds": "docs/validation/benchmark_thresholds.json",
      "required_checks": [
        "benchmark_result_json_roundtrip",
        "aggregate_benchmark_report_json",
        "benchmark_report_example_script",
        "benchmark_validation_errors",
        "benchmark_threshold_report",
        "ci_benchmark_artifact_upload",
        "small_seed_solve_timing",
        "jitted_local_fem_kernel_timing",
        "jitted_axisymmetric_global_assembly_apply_timing",
        "jitted_reduced_coil_green_response_timing",
        "jitted_circular_loop_elliptic_response_timing"
      ],
      "pass_rule": {
        "type": "executable_schema_and_threshold_sanity",
        "tolerance_source": "docs/validation/benchmark_thresholds.json"
      }
    },
    {
      "id": "manufactured-p1-poisson-convergence",
      "category": "manufactured_solution",
      "status": "implemented",
      "description": "Validate triangular p=1 Poisson convergence with H1 order one and L2 order two on shape-regular refinements.",
      "command": "python -m pytest tests/test_assembly.py tests/test_verification.py",
      "artifact": "docs/_static/manufactured_poisson_convergence.png",
      "required_checks": [
        "load_vector_assembly",
        "dirichlet_boundary_conditions",
        "refinement_sequence",
        "observed_h1_rate",
        "observed_l2_rate",
        "json_ready_convergence_report"
      ],
      "pass_rule": {
        "type": "observed_rate",
        "h1_expected_order": 1,
        "l2_expected_order": 2,
        "tolerance_source": "tests/test_assembly.py"
      }
    },
    {
      "id": "manufactured-axisymmetric-grad-shafranov-convergence",
      "category": "manufactured_solution",
      "status": "implemented",
      "description": "Validate self-adjoint axisymmetric Grad-Shafranov p=1 FEM convergence on a cylindrical-coordinate manufactured problem.",
      "command": "tokamaker-jax verify --gate grad-shafranov --subdivisions 4 8 16",
      "artifact": "docs/_static/manufactured_grad_shafranov_convergence.png",
      "required_checks": [
        "axisymmetric_inverse_radius_weight",
        "profile_source_density_convention",
        "exact_dirichlet_boundary_conditions",
        "true_quadrature_l2_error",
        "true_quadrature_weighted_h1_error",
        "observed_weighted_h1_rate",
        "observed_l2_rate",
        "json_ready_convergence_report",
        "finite_difference_vs_autodiff_weighted_stiffness"
      ],
      "pass_rule": {
        "type": "observed_rate",
        "weighted_h1_expected_order": 1,
        "l2_expected_order": 2,
        "tolerance_source": "tests/test_verification.py and tests/test_assembly.py"
      }
    },
    {
      "id": "reduced-free-boundary-coil-green",
      "category": "free_boundary",
      "status": "implemented",
      "description": "Validate the reduced large-aspect-ratio coil Green's-function fixture before full TokaMaker circular-filament parity.",
      "command": "tokamaker-jax verify --gate coil-green",
      "artifact": "docs/_static/coil_green_response.png",
      "required_checks": [
        "regularized_log_green_function",
        "coil_response_matrix_linearity",
        "coil_symmetry_about_centerline",
        "analytic_gradient_matches_jax_autodiff",
        "radial_log_ratio_identity",
        "json_ready_response_report",
        "gui_plot_metadata",
        "matplotlib_artifact"
      ],
      "pass_rule": {
        "type": "analytic_identity",
        "tolerance_source": "tests/test_free_boundary.py and tests/test_verification.py"
      }
    },
    {
      "id": "circular-loop-coil-elliptic-green",
      "category": "free_boundary",
      "status": "implemented",
      "description": "Validate a JAX-native circular-filament coil flux kernel using complete elliptic integrals evaluated by fixed-iteration AGM and checked against high-resolution toroidal quadrature.",
      "command": "tokamaker-jax verify --gate circular-loop",
      "artifact": "docs/_static/circular_loop_elliptic_response.png",
      "required_checks": [
        "agm_complete_elliptic_integrals_reference_values",
        "midplane_symmetry",
        "linear_superposition",
        "closed_form_matches_high_resolution_quadrature",
        "quadrature_convergence_against_high_resolution_reference",
        "finite_autodiff_flux_gradient",
        "autodiff_gradient_matches_exposed_gradient_api",
        "closed_form_gradient_matches_quadrature_gradient",
        "benchmark_report_lane"
      ],
      "pass_rule": {
        "type": "elliptic_closed_form_vs_quadrature_reference",
        "tolerance_source": "tests/test_free_boundary.py and tests/test_verification.py"
      }
    },
    {
      "id": "nonlinear-p1-profile-iteration",
      "category": "nonlinear_equilibrium",
      "status": "implemented",
      "description": "Validate a fixed-boundary p=1 triangular FEM Picard iteration with nonlinear pressure and FF' profile source terms.",
      "command": "tokamaker-jax verify --gate profile-iteration",
      "artifact": "docs/_static/profile_iteration.png",
      "required_checks": [
        "profile_flux_normalization",
        "constant_profile_load_oracle",
        "dirichlet_boundary_enforcement",
        "free_node_residual_norm",
        "finite_pressure_scale_gradient",
        "iteration_history_monotonicity",
        "json_ready_validation_report"
      ],
      "pass_rule": {
        "type": "analytic_oracle_and_residual_bound",
        "tolerance_source": "tests/test_fem_equilibrium.py"
      }
    },
    {
      "id": "free-boundary-profile-coupling",
      "category": "free_boundary",
      "status": "implemented",
      "description": "Validate the first coupled circular-loop coil boundary response plus nonlinear p=1 FEM profile iteration.",
      "command": "tokamaker-jax verify --gate free-boundary-profile",
      "artifact": "docs/_static/free_boundary_profile_coupling.png",
      "required_checks": [
        "circular_loop_response_matrix_linearity",
        "coil_flux_dirichlet_boundary_enforcement",
        "free_node_profile_residual",
        "coil_current_gradient_oracle",
        "finite_coupled_pressure_scale_gradient",
        "json_ready_validation_report",
        "matplotlib_coupling_artifact"
      ],
      "pass_rule": {
        "type": "coupled_oracle_and_residual_bound",
        "tolerance_source": "tests/test_verification.py and tests/test_cli_validate.py"
      }
    },
    {
      "id": "openfusiontoolkit-tokamaker-green-parity-probe",
      "category": "physics_parity",
      "status": "implemented_availability_gated",
      "description": "Probe the local OpenFUSIONToolkit checkout and compare the JAX circular-loop elliptic kernel against OpenFUSIONToolkit.TokaMaker.util.eval_green when the original compiled shared library is available.",
      "command": "tokamaker-jax verify --gate oft-parity",
      "artifact": "docs/_static/openfusiontoolkit_comparison_report.json",
      "required_checks": [
        "local_checkout_probe",
        "upstream_git_commit_recorded_when_available",
        "upstream_source_inventory_recorded",
        "compiled_library_import_status_recorded",
        "numeric_eval_green_comparison_when_available",
        "explicit_skip_status_when_unavailable"
      ],
      "pass_rule": {
        "type": "availability_gated_code_to_code",
        "relative_tolerance_when_available": 1e-10,
        "tolerance_source": "tests/test_comparison.py and tests/test_cli_validate.py"
      }
    },
    {
      "id": "fixed-boundary-upstream-evidence",
      "category": "physics_parity",
      "status": "implemented_source_evidence",
      "description": "Inventory upstream fixed-boundary notebooks and the gNT_example gEQDSK file, including stored upstream mesh counts, print_info scalars, and source workflow markers, without claiming solved-equilibrium parity.",
      "command": "python docs/validation/build_fixed_boundary_evidence.py --upstream-root /Users/rogeriojorge/local/OpenFUSIONToolkit --output docs/validation/fixed_boundary_upstream_evidence.json",
      "artifact": "docs/validation/fixed_boundary_upstream_evidence.json",
      "required_checks": [
        "fixed_boundary_ex1_notebook_sha256",
        "fixed_boundary_ex2_notebook_sha256",
        "gNT_example_sha256",
        "stored_triangle_mesh_counts",
        "stored_equilibrium_statistics",
        "gNT_eqdsk_header_and_profile_ranges",
        "explicit_no_numeric_parity_claim"
      ],
      "pass_rule": {
        "type": "source_audit_plus_stored_upstream_output",
        "numeric_parity_claim": false,
        "tolerance_source": "tests/test_fixed_boundary_evidence.py and tests/test_docs_artifacts.py"
      }
    },
    {
      "id": "free-boundary-tokamaker-parity",
      "category": "physics_parity",
      "status": "planned",
      "description": "Compare selected free-boundary equilibria against OpenFUSIONToolkit/TokaMaker fixtures with documented tolerances.",
      "command": null,
      "artifact": null,
      "required_checks": [
        "oft_fixture_import",
        "coil_response",
        "conductor_regions",
        "boundary_flux_error",
        "psi_axis_error",
        "xpoint_or_limiter_policy"
      ],
      "pass_rule": {
        "type": "code_to_code_fixture_specific",
        "tolerance_source": "future validation report"
      }
    }
  ],
  "literature_anchored_figures": [
    {
      "id": "tokamaker-cpc-seed-equilibrium-family",
      "status": "implemented_surrogate",
      "source": "Hansen et al., Computer Physics Communications 298, 109111 (2024)",
      "figure_id": "CPC paper equilibrium-family workflow surrogate",
      "reproduction_goal": "Generate a citation-linked seed fixed-boundary equilibrium family with scalar diagnostics, figure metadata, and explicit surrogate limitations while full OFT parity fixtures are still pending.",
      "command": "python examples/reproduce_cpc_seed_family.py outputs/literature/cpc_seed_family",
      "artifact": "docs/_static/cpc_seed_family.png",
      "report": "docs/_static/cpc_seed_family_report.json",
      "comparison_rule": "source-linked metadata, monotone pressure sweep diagnostics, finite solver residuals, and generated visual artifact; not yet a code-to-code TokaMaker parity claim"
    },
    {
      "id": "openfusiontoolkit-example-parity",
      "status": "planned",
      "source": "OpenFUSIONToolkit examples and documentation",
      "figure_id": "selected public TokaMaker example output",
      "reproduction_goal": "Reproduce the selected public example with source links, inputs, output image, and numerical comparison table.",
      "command": null,
      "artifact": null,
      "comparison_rule": "code-to-code fixture comparison"
    }
  ]
}
